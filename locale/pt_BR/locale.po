msgstr ""
"A coleta dos dados ocorre em acordo com a "
"<a href=\"{$privacyUrl}\" target=\"_blank\">declaração de privacidade</a> desta revista"

msgid "plugins.generic.deiaSurvey.questionnairePage.responses.title"
msgstr "Dados DEIA"

msgid "plugins.generic.deiaSurvey.questionnairePage.responsesFor.email"
msgstr "Mostrando dados associados ao endereço de e-mail: <strong>{$externalId}</strong>"

msgid "plugins.generic.deiaSurvey.questionnairePage.responsesFor.orcid"
msgstr "Mostrando dados associados ao ORCID: <strong>{$externalId}</strong>"

